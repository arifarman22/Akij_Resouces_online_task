# Neon PostgreSQL connection string
DATABASE_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# JWT Secrets
JWT_ACCESS_SECRET="change-me-to-a-strong-random-string-min-32-chars"
JWT_REFRESH_SECRET="change-me-to-a-strong-random-string-min-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="30"

# Built-in Employer Credentials
EMPLOYER_EMAIL="admin@akijresource.com"
EMPLOYER_PASSWORD="Admin@123456"
EMPLOYER_NAME="Akij Resource Admin"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
